---
const { id, eyebrow, title, body } = Astro.props;
---

<section class="section-block" id={id}>
  <div class="section-head">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {body && <p class="section-body">{body}</p>}
  </div>
  <div class="section-content">
    <slot />
  </div>
</section>
