---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteChrome from "../components/SiteChrome.astro";
import MetricStrip from "../components/MetricStrip.astro";
import SectionBlock from "../components/SectionBlock.astro";
import ModeCards from "../components/ModeCards.astro";
import ArtifactGrid from "../components/ArtifactGrid.astro";
import { artifactByLabel, metric, siteData, withBase } from "../utils/site-data";

const overviewMetrics = [
  {
    label: "Benchmark freeze",
    value: siteData.benchmark_version,
    detail: `Frozen on ${siteData.freeze_date}`,
  },
  {
    label: "Canonical cut",
    value: `${siteData.campaign_count} campaigns`,
    detail: `Closed on ${siteData.canonical_cut_date}`,
  },
  {
    label: "Safety-utility lead",
    value: `${metric(siteData.headline_metrics.successful_safe_completion_rate.delta_guarded_minus_strict)} uplift`,
    detail: "`guarded - strict` safe completion on `campaign-base-r5`",
  },
  {
    label: "Operational cost",
    value: `${metric(siteData.headline_metrics.operational_overhead.mean_latency_ms_delta_guarded_minus_strict, 3)} ms`,
    detail: `With +${metric(siteData.headline_metrics.operational_overhead.mean_token_usage_delta_guarded_minus_strict, 3)} mean tokens`,
  },
];

const artifactCards = [
  {
    kicker: "Canonical package",
    title: "Statistical artifact",
    body: "The public JSON behind the site, the paper-ready tables, and the frozen post-freeze campaign cut.",
    href: withBase(`/${artifactByLabel("final-nineteen-campaigns.json").site_path}`),
    source: artifactByLabel("final-nineteen-campaigns.json").source,
  },
  {
    kicker: "Freeze identity",
    title: "Benchmark manifest",
    body: "The artifact readers need to understand what belongs to benchmark identity and what is only an execution condition.",
    href: withBase(`/${artifactByLabel("benchmark_manifest.json").site_path}`),
    source: artifactByLabel("benchmark_manifest.json").source,
  },
  {
    kicker: "Narrative bridge",
    title: "Paper-ready results",
    body: "The compact English results narrative aligned with the public-facing interpretation on this site.",
    href: withBase(`/${artifactByLabel("results.md").site_path}`),
    source: artifactByLabel("results.md").source,
  },
];
---

<BaseLayout title="Agent Contracts Benchmark" description="Project companion for the frozen benchmark-v1.0 study on agent contracts and runtime governance.">
  <SiteChrome>
    <section class="page-intro page-intro-home">
      <p class="eyebrow">Benchmark companion</p>
      <h1>Frozen benchmark definition and canonical post-freeze evidence.</h1>
      <p>
        This site provides a compact public companion to the frozen benchmark, the canonical 19-campaign evidence cut,
        and the principal H1-H4 results.
      </p>
      <div class="intro-links">
        <a href={withBase("/results")}>Results</a>
        <a href={withBase("/methodology")}>Methodology</a>
        <a href={withBase("/artifacts")}>Artifacts</a>
      </div>
    </section>

    <MetricStrip items={overviewMetrics} />

    <SectionBlock
      id="question"
      eyebrow="Research question"
      title="Can runtime governance control a tool-using LLM agent without collapsing utility?"
      body="The benchmark fixes the environment, scenario set, and evaluation rules, then compares enforcement modes under a common frozen task set."
    >
      <div class="content-grid">
        <div class="story-card">
          <p>
            This site is a public research companion for the frozen benchmark artifact. It is organized to foreground the evidence base,
            support reproducibility, and distinguish clearly between canonical and exploratory materials.
          </p>
        </div>
        <div class="story-card story-card-accent">
          <p class="eyebrow">Contents</p>
          <ul>
            <li>The frozen benchmark definition and its methodological limits.</li>
            <li>The canonical 19-campaign post-freeze cut dated <code>2026-06-25</code>.</li>
            <li>The public English narrative for H1-H4.</li>
            <li>Curated artifact links for auditability and reproducibility.</li>
          </ul>
        </div>
      </div>
    </SectionBlock>

    <SectionBlock
      id="modes"
      eyebrow="Enforcement modes"
      title="Four execution conditions, one frozen benchmark."
      body="Model profiles vary by campaign, but the benchmark identity remains fixed. These modes define the main experimental contrast reported across methodology and results."
    >
      <ModeCards modes={siteData.modes} />
    </SectionBlock>

    <SectionBlock
      id="evidence"
      eyebrow="Public materials"
      title="Core public materials"
      body="The public artifact layer centers on the benchmark definition, the canonical statistics package, and the compact results narrative."
    >
      <ArtifactGrid items={artifactCards} />
    </SectionBlock>
  </SiteChrome>
</BaseLayout>
