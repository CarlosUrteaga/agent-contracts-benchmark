# Azure OpenAI / Azure AI Foundry OpenAI deployments through LiteLLM.
# Set model_id in benchmark/enforcement/config/model_profiles/azure_foundry_openai.yaml
# to azure/<your-deployment-name>.
AZURE_API_KEY=
AZURE_API_BASE=https://<resource-name>.openai.azure.com
AZURE_API_VERSION=<api-version-for-your-deployment>

# Azure AI Foundry Claude through LiteLLM azure_ai/.
# For Claude, the base URL usually ends with /anthropic.
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=https://<resource-name>.services.ai.azure.com/anthropic
